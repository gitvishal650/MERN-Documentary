<%- include('./base/header.ejs') %>
    <div class="container">
        <div class="alert bg-success my-3">
           <h4 class="text-center text-white">Edit Student</h4> 
        </div>
    </div>
    <div class="container">
        <div class="row">
            <div class="col"></div>
            <div class="col">
                <form action="/update/student/<%=student._id%>" method='post'>

                <div>
                    <label class="form-label">Roll No</label>
                    <input type="text" class="form-control" placeholder="Enter Roll No" value="<%=student.rollno%>" name="rollno">
                </div>
                <div>
                    <label class="form-label">Name</label>
                    <input type="text" class="form-control" placeholder="Enter Name" value="<%=student.name%>" name="name">
                </div>
                <div>
                    <label class="form-label">FatherName</label>
                    <input type="text" class="form-control" placeholder="Enter Father Name" value="<%=student.fatherName%>" name="fatherName">
                </div>
                <div>
                    <label class="form-label">Aadhar Card No</label>
                    <input type="text" class="form-control" placeholder="Mobile No" value="<%=student.adharCardNo%>" name="adharCardNo">
                </div>
                <div>
                    <label class="form-label">Mobile No</label>
                    <input type="text" class="form-control" placeholder="Mobile No" value="<%=student.mobileNo%>" name="mobileNo">
                </div>

                <div>
                    <input type="submit" class="btn btn-success mt-3" value="Update Student">
                    <a href="/students" class="btn btn-danger mt-3">Cancel</a>
                </div>
            </form>
            </div>
            <div class="col"></div>
        </div>
    </div>
<%- include('./base/footer.ejs') %>